{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/qframe-be/test-gaw-release-workflow/.releases/cab/impact.schema.json",
  "title": "CAB Release Impact Assessment",
  "description": "Schema for the Change Advisory Board (CAB) impact assessment generated for each published release. Mirrors the CAB form categories (Security, Infrastructuur, Integraties, Functioneel).",
  "type": "object",
  "additionalProperties": false,
  "required": ["release", "impact"],
  "definitions": {
    "impactCategory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "notes"],
      "properties": {
        "level": {
          "type": "string",
          "description": "Impact level for this category.",
          "enum": ["low", "medium", "high"]
        },
        "notes": {
          "type": "array",
          "description": "Toelichting (explanation). Required and non-empty when level is medium or high.",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "level": { "enum": ["medium", "high"] } },
            "required": ["level"]
          },
          "then": {
            "properties": { "notes": { "type": "array", "minItems": 1 } }
          }
        }
      ]
    }
  },
  "properties": {
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tag", "publishedAt", "repository"],
      "properties": {
        "tag": {
          "type": "string",
          "description": "The published release tag (e.g. v1.2.0)."
        },
        "previousTag": {
          "type": ["string", "null"],
          "description": "The previous release tag used as the diff base, or null if this is the first release."
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp of when the release was published."
        },
        "repository": {
          "type": "string",
          "description": "The owner/repo this release belongs to."
        }
      }
    },
    "impact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["security", "infrastructure", "integrations", "functional"],
      "properties": {
        "security": { "$ref": "#/definitions/impactCategory" },
        "infrastructure": { "$ref": "#/definitions/impactCategory" },
        "integrations": { "$ref": "#/definitions/impactCategory" },
        "functional": { "$ref": "#/definitions/impactCategory" }
      }
    }
  }
}
